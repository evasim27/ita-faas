{
  "info": {
    "name": "ITA FaaS – Tržnica Oglasov",
    "description": "Testiranje Firebase Cloud Functions.\n\nBASE_URL = http://127.0.0.1:5001/ita-faas-3fd3b/us-central1\n\nonRequest funkcije: navaden HTTP klic\nonCall funkcije: POST z { data: {...} } in Bearer token",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://127.0.0.1:5001/ita-faas-3fd3b/us-central1" },
    { "key": "AUTH_URL", "value": "http://127.0.0.1:9099" },
    { "key": "TOKEN", "value": "" },
    { "key": "OGLAS_ID", "value": "" }
  ],
  "item": [
    {
      "name": "0. Pridobi token (Auth Emulator)",
      "item": [
        {
          "name": "0a. Registracija – ustvari testnega uporabnika",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "if (r.idToken) { pm.collectionVariables.set('TOKEN', r.idToken); pm.test('Token shranjen', () => pm.expect(r.idToken).to.be.a('string')); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"geslo123\",\n  \"returnSecureToken\": true\n}"
            },
            "url": {
              "raw": "{{AUTH_URL}}/identitytoolkit.googleapis.com/v1/accounts:signUp?key=fake-api-key",
              "host": ["{{AUTH_URL}}"],
              "path": ["identitytoolkit.googleapis.com", "v1", "accounts:signUp"],
              "query": [{ "key": "key", "value": "fake-api-key" }]
            },
            "description": "Ustvari novega uporabnika v Auth Emulatorju in shrani token v spremenljivko TOKEN."
          }
        },
        {
          "name": "0b. Prijava – pridobi svež token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "if (r.idToken) { pm.collectionVariables.set('TOKEN', r.idToken); pm.test('Token shranjen', () => pm.expect(r.idToken).to.be.a('string')); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"geslo123\",\n  \"returnSecureToken\": true\n}"
            },
            "url": {
              "raw": "{{AUTH_URL}}/identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=fake-api-key",
              "host": ["{{AUTH_URL}}"],
              "path": ["identitytoolkit.googleapis.com", "v1", "accounts:signInWithPassword"],
              "query": [{ "key": "key", "value": "fake-api-key" }]
            },
            "description": "Prijava obstoječega uporabnika. Token se shrani v spremenljivko TOKEN."
          }
        }
      ]
    },
    {
      "name": "1. Profili (onCall)",
      "item": [
        {
          "name": "1a. Pridobi profil",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"data\": {}\n}" },
            "url": {
              "raw": "{{BASE_URL}}/pridobiProfil",
              "host": ["{{BASE_URL}}"],
              "path": ["pridobiProfil"]
            },
            "description": "onCall – vrne profil prijavljenega uporabnika."
          }
        },
        {
          "name": "1b. Posodobi profil",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"ime\": \"Ana Novak\",\n    \"telefon\": \"041 123 456\",\n    \"lokacija\": \"Ljubljana\"\n  }\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/posodobiProfil",
              "host": ["{{BASE_URL}}"],
              "path": ["posodobiProfil"]
            },
            "description": "onCall – posodobi ime, telefon, lokacijo."
          }
        }
      ]
    },
    {
      "name": "2. Oglasi",
      "item": [
        {
          "name": "2a. Pridobi vse oglase (onRequest – javno)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/pridobiOglase",
              "host": ["{{BASE_URL}}"],
              "path": ["pridobiOglase"]
            },
            "description": "onRequest – javni endpoint, ne zahteva tokena."
          }
        },
        {
          "name": "2b. Pridobi en oglas (onRequest – javno)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/pridobiOglas?id={{OGLAS_ID}}",
              "host": ["{{BASE_URL}}"],
              "path": ["pridobiOglas"],
              "query": [{ "key": "id", "value": "{{OGLAS_ID}}" }]
            },
            "description": "onRequest – javni endpoint."
          }
        },
        {
          "name": "2c. Objavi oglas (onCall)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var r = pm.response.json();",
                  "if (r.result && r.result.id) { pm.collectionVariables.set('OGLAS_ID', r.result.id); pm.test('OGLAS_ID shranjen', () => pm.expect(r.result.id).to.be.a('string')); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"naslov\": \"iPhone 14 Pro – odlično stanje\",\n    \"opis\": \"Malo rabljen, brez praske. Komplet z originalno škatlo.\",\n    \"cena\": 750,\n    \"kategorija\": \"elektronika\"\n  }\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/objavaOglasa",
              "host": ["{{BASE_URL}}"],
              "path": ["objavaOglasa"]
            },
            "description": "onCall – ustvari oglas. ID se shrani v OGLAS_ID."
          }
        },
        {
          "name": "2d. Posodobi oglas (onCall)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"id\": \"{{OGLAS_ID}}\",\n    \"naslov\": \"iPhone 14 Pro – ZNIŽANO\",\n    \"cena\": 680\n  }\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/posodobiOglas",
              "host": ["{{BASE_URL}}"],
              "path": ["posodobiOglas"]
            },
            "description": "onCall – posodobi oglas. Dovoljeno samo lastniku."
          }
        },
        {
          "name": "2e. Izbriši oglas (onCall)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"id\": \"{{OGLAS_ID}}\"\n  }\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/izbrisiOglas",
              "host": ["{{BASE_URL}}"],
              "path": ["izbrisiOglas"]
            },
            "description": "onCall – izbriše oglas. Dovoljeno samo lastniku."
          }
        },
        {
          "name": "2f. [401] Objavi oglas brez tokena",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"naslov\": \"Test brez auth\",\n    \"opis\": \"Mora vrniti unauthenticated.\",\n    \"cena\": 10,\n    \"kategorija\": \"ostalo\"\n  }\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/objavaOglasa",
              "host": ["{{BASE_URL}}"],
              "path": ["objavaOglasa"]
            },
            "description": "Pričakovano: napaka unauthenticated."
          }
        }
      ]
    },
    {
      "name": "3. Sporočanje (onCall)",
      "item": [
        {
          "name": "3a. Pošlji sporočilo",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"oglasId\": \"{{OGLAS_ID}}\",\n    \"vsebina\": \"Pozdravljeni, ali je artikel še na voljo?\"\n  }\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/posljiSporocilo",
              "host": ["{{BASE_URL}}"],
              "path": ["posljiSporocilo"]
            },
            "description": "onCall – pošlje sporočilo prodajalcu."
          }
        },
        {
          "name": "3b. Pridobi sporočila",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"oglasId\": \"{{OGLAS_ID}}\"\n  }\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/pridobiSporocila",
              "host": ["{{BASE_URL}}"],
              "path": ["pridobiSporocila"]
            },
            "description": "onCall – vrne sporočila za oglas. Samo lastnik oglasa."
          }
        }
      ]
    }
  ]
}
